      </column>
      <column caption='total bhev vehicles' datatype='integer' name='[Calculation_1018199886512132]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(if [Electric Vehicle Type]=&quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot; THEN [DOL Vehicle ID]END)' />
