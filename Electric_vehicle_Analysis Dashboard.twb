      <column caption='Total BEV vehicles' datatype='integer' name='[Calculation_1018199885103106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD( IF [Electric Vehicle Type]= &quot;Battery Electric Vehicle (BEV)&quot; THEN [DOL Vehicle ID] END)' />
      </column>
      <column caption='% of BEV vehicles' datatype='real' name='[Calculation_1018199886086147]' role='measure' type='quantitative'>
